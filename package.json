{
	"name": "setup-opentofu",
	"version": "2.0.0",
	"description": "Setup OpenTofu CLI for GitHub Actions",
	"type": "module",
	"license": "MPL-2.0",
	"publisher": "step-security",
	"main": "index.js",
	"repository": {
		"type": "git",
		"url": "https://github.com/step-security/setup-opentofu.git"
	},
	"scripts": {
		"test": "semistandard --env jest && node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage",
		"lint": "semistandard --env jest --fix",
		"build": "ncc build wrapper/tofu.js --out wrapper/dist && ncc build index.js --out dist",
		"format-check": "echo \"unimplemented for actions/reusable-workflows basic-validation\""
	},
	"keywords": [],
	"author": "step-security",
	"dependencies": {
		"@actions/core": "^3.0.0",
		"@actions/exec": "^3.0.0",
		"@actions/http-client": "^4.0.0",
		"@actions/io": "^3.0.2",
		"@actions/tool-cache": "^4.0.0",
		"axios": "^1.13.6",
		"semver": "^7.7.4"
	},
	"devDependencies": {
		"@vercel/ncc": "0.38.4",
		"jest": "^30.3.0",
		"semistandard": "17.0.0"
	},
	"semistandard": {
		"ignore": [
			"**/dist/**"
		]
	}
}
